# SmartLearn gateway runtime
OPENCLAW_API_URL=http://localhost:8000
MONGO_URL=mongodb://localhost:27017/smartlearn
DB_URL=mongodb://db:27017/smartlearn
DB_NAME=smartlearn
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080
CORS_ALLOW_ALL=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_USERNAMES=admin

# Native OpenClaw container
OPENCLAW_NATIVE_IMAGE=harbor.dockerin.com/library/openclaw-ubuntu2404:v1.0.1
OPENCLAW_NATIVE_PORT=18789
OPENCLAW_NATIVE_ALT_PORT=1455
OPENCLAW_ALLOW_UNCONFIGURED=true
OPENCLAW_CONFIG_DIR=./deploy/openclaw/config
OPENCLAW_ROOT_DATA_DIR=./deploy/openclaw/root
TZ=Asia/Shanghai

# Native OpenClaw routing (gateway -> native)
SKILL_BACKEND=openclaw
OPENCLAW_NATIVE_URL=http://openclaw-native:18789
OPENCLAW_NATIVE_TOKEN=
REMOTE_TIMEOUT_SECONDS=25

# LLM (Qwen via DashScope compatible API)
LLM_PROVIDER=qwen
MODEL=qwen-plus
QWEN_MODEL=qwen-plus
QWEN_API_KEY=your-dashscope-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=60

# Frontend public runtime
NEXT_PUBLIC_OPENCLAW_API_URL=http://localhost:8000